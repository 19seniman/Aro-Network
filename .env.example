# ============================================
#  ARO NETWORK MONITOR — Konfigurasi .env
# ============================================
# Salin file ini menjadi .env lalu isi nilainya
# cp .env.example .env

# --- Token Autentikasi ---
# Cara ambil token:
# 1. Login di https://dashboard.aro.network
# 2. F12 → Network → Filter XHR/Fetch → Refresh halaman
# 3. Klik salah satu request → Headers → cari "Authorization: Bearer ..."
# 4. Copy token (tanpa kata "Bearer")
ARO_TOKEN=paste_token_kamu_di_sini

# --- Kredensial (untuk auto-refresh token) ---
ARO_EMAIL=email_kamu@gmail.com
ARO_PASSWORD=password_kamu

# --- Base URL API ---
# Sesuaikan jika endpoint berubah
ARO_API_BASE=https://api.aro.network

# --- Interval Monitoring (dalam menit) ---
# Default: cek status node setiap 5 menit
MONITOR_INTERVAL_MINUTES=5

# --- Notifikasi ---
# Kirim notifikasi ke console saat node offline
NOTIFY_ON_OFFLINE=true
# Kirim notifikasi saat node kembali online
NOTIFY_ON_RECOVERY=true
# Kirim ringkasan rewards setiap hari
NOTIFY_DAILY_SUMMARY=true
# Jam pengiriman ringkasan harian (format 24 jam)
DAILY_SUMMARY_HOUR=8
